{
  "name": "EmergencyContact",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Contact name"
    },
    "phone": {
      "type": "string",
      "description": "Phone number"
    },
    "email": {
      "type": "string",
      "description": "Email address for emergency email alerts"
    },
    "relationship": {
      "type": "string",
      "enum": [
        "parent",
        "spouse",
        "sibling",
        "friend",
        "guardian",
        "other"
      ],
      "description": "Relationship to user"
    },
    "is_primary": {
      "type": "boolean",
      "default": false,
      "description": "Primary emergency contact"
    },
    "avatar_url": {
      "type": "string",
      "description": "Avatar image URL"
    }
  },
  "required": [
    "name",
    "phone"
  ]
}